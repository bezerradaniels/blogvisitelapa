# URL pública do site (host canônico, sem www, sem barra no final).
# Dirige SEO, sitemap e o redirect_to dos e-mails de auth — precisa bater com o
# Site URL do Supabase e com o host onde os usuários acessam (senão o PKCE quebra).
NEXT_PUBLIC_SITE_URL=https://conectalapa.com.br

# Supabase — encontre em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (SOMENTE no servidor — NUNCA exponha ao cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Segredo longo usado exclusivamente pelo cron do servidor para chamar
# POST /api/internal/comercial/sincronizar com Authorization: Bearer <segredo>.
COMMERCIAL_SYNC_SECRET=

# Resend — envio de e-mails transacionais do app (ex.: aviso de senha alterada)
# Crie uma API Key em https://resend.com/api-keys (domínio conectalapa.com.br verificado)
RESEND_API_KEY=
# Remetente. Precisa usar o domínio verificado no Resend.
EMAIL_FROM="Conecta Lapa <nao-responda@conectalapa.com.br>"

# Google AdSense (client id do formato ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Verificação de propriedade no Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
