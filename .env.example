# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://www.visitelapa.com.br

# Supabase — encontre em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (SOMENTE no servidor — NUNCA exponha ao cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Google AdSense (client id do formato ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Verificação de propriedade no Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
