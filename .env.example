# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://www.conectalapa.com.br

# Supabase — encontre em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (SOMENTE no servidor — NUNCA exponha ao cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Resend — envio de e-mails transacionais do app (ex.: aviso de senha alterada)
# Crie uma API Key em https://resend.com/api-keys (domínio conectalapa.com.br verificado)
RESEND_API_KEY=
# Remetente. Precisa usar o domínio verificado no Resend.
EMAIL_FROM="Conecta Lapa <nao-responda@conectalapa.com.br>"

# Google AdSense (client id do formato ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Verificação de propriedade no Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
